# ============================================================
#  URLs propres : tout ce qui n'est pas un fichier réel
#  (assets, images…) est envoyé au routeur index.php
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Laisser servir directement les fichiers et dossiers existants
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tout le reste passe par le routeur
    RewriteRule ^ index.php [L]
</IfModule>

# Page d'erreur 404 gérée par PHP même en accès direct à un .php inexistant
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# Empêcher le listage des dossiers
Options -Indexes

# Ne pas exposer les fichiers sensibles
<FilesMatch "\.(json|md|tmp)$">
    Require all denied
</FilesMatch>

# ============================================================
#  Cache navigateur des fichiers statiques (perf / Lighthouse).
#  Tout est sous <IfModule> : sans effet — et sans erreur 500 —
#  si le module n'est pas chargé chez l'hébergeur.
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    # Images (dont les frames .webp de l'animation), polices, vidéo :
    # changent rarement et changent de nom quand elles changent → cache long.
    ExpiresByType image/webp             "access plus 1 year"
    ExpiresByType image/png              "access plus 1 year"
    ExpiresByType image/jpeg             "access plus 1 year"
    ExpiresByType image/gif              "access plus 1 year"
    ExpiresByType image/svg+xml          "access plus 1 year"
    ExpiresByType image/x-icon           "access plus 1 year"
    ExpiresByType video/mp4              "access plus 1 year"
    ExpiresByType font/woff2             "access plus 1 year"
    ExpiresByType font/woff              "access plus 1 year"
    # CSS / JS : pas de cache-busting → cache court pour que les mises à jour
    # se propagent vite (1 jour).
    ExpiresByType text/css               "access plus 1 day"
    ExpiresByType application/javascript "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
    # immutable uniquement pour les fichiers « versionnés par leur nom »
    <FilesMatch "\.(webp|png|jpe?g|gif|svg|ico|mp4|woff2?)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>
